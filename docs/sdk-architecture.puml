@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam shadowing false

interface Node #E0E0E0 {
    id: string
    label: string
    --
    to(target: Node, label?): Connection
}

abstract class Shape #E8EAF6 {
    id: string
    label: string
    x?, y?: number
    width?, height?: number
    style?: StyleOpts
    --
    outline(w, h): Float64Array
    clipPoint(w, h, angle): [x, y]
    labelPos(w, h): [x, y]
    toJSON(): object
}

class Group #E8EAF6 {
    id: string
    label: string
    children: (Shape | Group)[]
    style?: GroupStyle
    --
    add(el: Shape): Shape
    group(label, opts?): Group
    toJSON(): object
}

Node <|.. Shape : implements
Node <|.. Group : implements

Group o-- "0..*" Shape : contains
Group o-- "0..*" Group : subgroups

class Rectangle #D1C4E9
class Ellipse #D1C4E9
class Diamond #D1C4E9
class Database #FFE0B2
class Queue #FFE0B2
class Lambda #FFE0B2

Shape <|-- Rectangle
Shape <|-- Ellipse
Shape <|-- Diamond
Shape <|-- Database
Shape <|-- Queue
Shape <|-- Lambda

class Connection #BBDEFB {
    from: Node
    to: Node
    label?: string
    type: "arrow" | "line"
}

Node --> Connection : creates via to()

class Diagram #E3F2FD {
    title?: string
    children: (Shape | Group)[]
    connections: Connection[]
    layout: Layout
    --
    add(el: Shape): Shape
    group(label, opts?): Group
    publish(engine: Engine): url
    toJSON(): object
}

Diagram o-- "0..*" Shape
Diagram o-- "0..*" Group
Diagram o-- "0..*" Connection
Diagram *-- Layout

abstract class Engine #C8E6C9 {
    name: string
    --
    render(d: Diagram): Uint8Array | string
    toJSON(): object
}

class CleanEngine #A5D6A7 {
    font = 1 (Nunito Bold)
    << default >>
}

class RoughEngine #A5D6A7 {
    roughness: number
    seed: number
    font = 0 (Architects Daughter)
}

class PumlEngine #A5D6A7 {
    renders to PlantUML text
}

class MermaidEngine #A5D6A7 {
    renders to Mermaid text
}

Engine <|-- CleanEngine
Engine <|-- RoughEngine
Engine <|-- PumlEngine
Engine <|-- MermaidEngine

abstract class Layout #B2DFDB {
    name: string
    --
    apply(d: Diagram)
    toJSON(): object
}

class Sugiyama #80CBC4 {
    direction: TB|LR|BT|RL
    spacing: number
    << default >>
}

class Grid #80CBC4 {
    columns: number
    spacing: number
}

Layout <|-- Sugiyama
Layout <|-- Grid

class WasmCanvas <<Rust>> #FFCDD2 {
    new(w, h)
    clear(color: u32)
    fill_path(segs, color)
    stroke_path(segs, color, w)
    draw_text(text, x, y, size, color, font)
    measure_text(text, size, font): [w,h]
    to_png(): Uint8Array
    to_image_data(): Uint8Array
}

class Diagramz <<static>> #E3F2FD {
    {static} toCode(json): string
    {static} fromJson(json): Diagram
}

CleanEngine ..> WasmCanvas : uses
RoughEngine ..> WasmCanvas : uses
Diagramz ..> Diagram
Diagram ..> Engine : publish delegates

@enduml
