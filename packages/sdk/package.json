{
  "name": "diagramz",
  "version": "0.1.7",
  "description": "Diagrams as code — build, render, and share diagrams from JavaScript",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./shapes/basic": "./dist/shapes/basic.js",
    "./shapes/uml": "./dist/shapes/uml.js",
    "./shapes/c4": "./dist/shapes/c4.js",
    "./engines": "./dist/engines/index.js",
    "./layout": "./dist/layout/index.js",
    "./themes": "./dist/themes/index.js",
    "./wasm-canvas": "./dist/wasm-canvas.js"
  },
  "bin": {
    "diagramz": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/wasm && cp src/wasm/diagramz_renderer.cjs src/wasm/diagramz_renderer_bg.wasm dist/wasm/",
    "dev": "tsc --watch"
  },
  "keywords": [
    "diagram",
    "wasm",
    "rendering",
    "cli",
    "canvas"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pawel-608/diagramz.git",
    "directory": "packages/sdk"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dts-bundle-generator": "^9.5.1",
    "typescript": "^5.7.0"
  }
}
